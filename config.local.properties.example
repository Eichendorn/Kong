# Copy this file to config.local.properties and fill in your values.
# config.local.properties is gitignored so the token never gets committed.
#
# You can also supply any of these via environment variables instead
# (JIRA_BASE_URL, JIRA_EMAIL, JIRA_TOKEN, JIRA_BOARDS, PORT).
# Environment variables win over this file.

jira.baseUrl=https://fnba.atlassian.net
jira.email=Chris.Gallo@fnba.com
jira.token=PASTE_YOUR_API_TOKEN_HERE

# Comma-separated board definitions shown in the UI: label|jql
# (one entry per pipe-delimited pair, entries separated by ;;)
jira.boards=MIN - Encompass Work|project = MIN ORDER BY updated DESC

# HTTP port for the local web app.
server.port=7070
